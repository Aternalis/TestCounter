<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Mobile Domino</title>
    <style>
        /* Mobile Reset and Setup */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent; /* Removes flash on mobile tap */
        }

        body, html {
            height: 100%;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: #1a1a1a;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 10px;
        }

        /* The Domino Container */
        .domino {
            width: 100%;
            max-width: 400px;
            height: 90vh; /* Takes up most of the mobile screen vertically */
            background-color: #2a2a2a;
            border: 6px solid #fff;
            border-radius: 24px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        }

        /* The Center Dividing Line */
        .domino::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 5%;
            right: 5%;
            height: 6px;
            background-color: #fff;
            transform: translateY(-50%);
            border-radius: 3px;
        }

        /* Top and Bottom Halves */
        .domino-half {
            flex: 1;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: repeat(3, 1fr);
            gap: 20px;
            padding: 30px;
            align-items: center;
            justify-items: center;
        }

        /* The Interactive Circles (Pips) */
        .pip {
            width: 65px;
            height: 65px;
            border-radius: 50%;
            background-color: #fff;
            border: 3px solid #fff;
            transition: background-color 0.2s, transform 0.1s;
            cursor: pointer;
        }

        /* Toggled Black State */
        .pip.black {
            background-color: #000;
        }

        /* Active feedback for touch screens */
        .pip:active {
            transform: scale(0.92);
        }

        /* The Text Input Squares */
        .input-square {
            width: 65px;
            height: 65px;
            border: 3px solid #fff;
            background-color: transparent;
            color: #fff;
            border-radius: 8px;
            text-align: center;
            font-size: 1.5rem;
            font-weight: bold;
            outline: none;
        }

        .input-square:focus {
            border-color: #0070f3;
            background-color: rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body>

    <div class="domino">
        <div class="domino-half" id="top-half">
            <input type="text" class="input-square" maxlength="2">
            <input type="text" class="input-square" maxlength="2">
            <div class="pip" onclick="togglePip(this)"></div>
            <div class="pip" onclick="togglePip(this)"></div>
            <div class="pip" onclick="togglePip(this)"></div>
            <div class="pip" onclick="togglePip(this)"></div>
        </div>

        <div class="domino-half" id="bottom-half">
            <div class="pip" onclick="togglePip(this)"></div>
            <div class="pip" onclick="togglePip(this)"></div>
            <div class="pip" onclick="togglePip(this)"></div>
            <div class="pip" onclick="togglePip(this)"></div>
            <input type="text" class="input-square" maxlength="2">
            <input type="text" class="input-square" maxlength="2">
        </div>
    </div>

    <script>
        // JavaScript to handle the tapping/toggling of the circles
        function togglePip(element) {
            element.classList.toggle('black');
        }
    </script>

</body>
</html>
